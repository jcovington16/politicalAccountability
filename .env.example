# Local database settings for scripts/db/liquibase.sh.
# Copy to .env for local development. Do not commit real secrets.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=political_data
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Optional: override the full JDBC URL.
# DATABASE_URL=jdbc:postgresql://localhost:5432/political_data

# Optional: pin or override the Docker fallback image.
# LIQUIBASE_IMAGE=liquibase:4.33

# Optional: use host networking for Liquibase Docker validation in CI.
# LIQUIBASE_DOCKER_NETWORK=host

# Local ingestion/search settings.
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
INGEST_INPUT_DIR=data/ingestion

# External data-source API keys. Keep real values in local .env or a secrets
# manager only; never commit them.
CONGRESS_API_KEY=
GOVINFO_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
GOOGLE_CIVIC_API_KEY=
COURTLISTENER_API_KEY=
NEWSAPI_API_KEY=

# Congress.gov ingestion controls.
CONGRESS_NUMBER=119
# Optional bill type filter: hr, s, hjres, sjres, hconres, sconres, hres, sres
# CONGRESS_BILL_TYPE=hr
CONGRESS_BILL_LIMIT=20

# GovInfo ingestion controls. Collection examples: BILLS, BILLSTATUS, CREC, PLAW, FR.
GOVINFO_COLLECTION=BILLS
# ISO-8601 timestamp. Default is the last 7 days when omitted.
# GOVINFO_START_DATE_TIME=2026-01-01T00:00:00Z
GOVINFO_PAGE_SIZE=10
