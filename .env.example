# Local database settings for scripts/db/liquibase.sh.
# Copy to .env for local development. Do not commit real secrets.

DB_HOST=localhost
DB_PORT=5434
DB_NAME=political_data
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Optional: override the full JDBC URL.
# DATABASE_URL=jdbc:postgresql://localhost:5434/political_data

# Optional: pin or override the Docker fallback image.
# LIQUIBASE_IMAGE=liquibase:4.33

# Optional: use host networking for Liquibase Docker validation in CI.
# LIQUIBASE_DOCKER_NETWORK=host

# Local ingestion/search settings.
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
INGEST_INPUT_DIR=data/ingestion
INGEST_HTTP_MAX_ATTEMPTS=3
INGEST_HTTP_BACKOFF_MS=1000

# Internal/admin API access for import visibility and audit endpoints.
# Use a long random value outside local development.
ADMIN_API_TOKEN=local-admin-token

# Public search abuse-prevention controls.
RATE_LIMIT_ENABLED=true
PUBLIC_SEARCH_RATE_LIMIT_PER_MINUTE=60

# External data-source API keys. Keep real values in local .env or a secrets
# manager only; never commit them.
CONGRESS_API_KEY=
GOVINFO_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
GOOGLE_CIVIC_API_KEY=
COURTLISTENER_API_KEY=
NEWSAPI_API_KEY=
GUARDIAN_API_KEY=
YOUTUBE_API_KEY=
X_BEARER_TOKEN=

# Congress.gov ingestion controls.
CONGRESS_NUMBER=119
# Optional bill type filter: hr, s, hjres, sjres, hconres, sconres, hres, sres
# CONGRESS_BILL_TYPE=hr
CONGRESS_BILL_LIMIT=20
# Optional member import controls. Set CONGRESS_MEMBER_STATE=FL to seed Florida
# members, including current/former members returned by Congress.gov.
# CONGRESS_MEMBER_STATE=FL
# CONGRESS_CURRENT_MEMBER=false
CONGRESS_MEMBER_LIMIT=250

# Open States ingestion controls.
OPENSTATES_JURISDICTION=ocd-jurisdiction/country:us/state:co/government
# Optional: set this to a known state legislative session identifier.
# OPENSTATES_SESSION=2025A
OPENSTATES_LIMIT=25

# Google Civic representatives lookup. Use an address inside the district/state
# you want to seed locally.
GOOGLE_CIVIC_ADDRESS=

# GovInfo ingestion controls. Collection examples: BILLS, BILLSTATUS, CREC, PLAW, FR.
GOVINFO_COLLECTION=BILLS
# ISO-8601 timestamp. Default is the last 7 days when omitted.
# GOVINFO_START_DATE_TIME=2026-01-01T00:00:00Z
GOVINFO_PAGE_SIZE=10

# Public media discovery. These records are citation candidates, not verified
# facts. Use official APIs/feeds and keep limits small while developing.
# GDELT is free and does not require an API key.
GDELT_QUERIES="Marco Rubio healthcare,Marco Rubio voting record"
GDELT_MAX_RECORDS=10
# Comma-separated feed URLs. Optionally label a feed as url|Source Name.
RSS_FEEDS="https://www.congress.gov/rss/most-viewed-bills.xml|Congress.gov Most Viewed Bills"
# Guardian Open Platform uses the Guardian API key above.
GUARDIAN_QUERIES="Marco Rubio healthcare,Marco Rubio voting record"
GUARDIAN_PAGE_SIZE=10
# YouTube uses the official YouTube Data API key above. Use public search
# queries and/or specific official channel IDs.
YOUTUBE_QUERIES="Marco Rubio hearing,Marco Rubio interview"
YOUTUBE_CHANNEL_IDS=
YOUTUBE_MAX_RESULTS=5
# Public social discovery. Social posts are stored as citation candidates and
# should be linked only to verified social accounts before public display.
BLUESKY_QUERIES="Marco Rubio"
BLUESKY_LIMIT=25
X_QUERIES="from:marcorubio"
X_MAX_RESULTS=10

# Optional HTML article scraper. Prefer APIs/RSS first. Only enable this for
# explicit public article URLs from reputable sources after checking terms and
# robots.txt. Do not use it for paywalled, login-gated, private, or bulk crawling.
NEWS_SCRAPER_ENABLED=false
NEWS_SCRAPER_URLS="https://example.org/politics/article|Example News"
NEWS_SCRAPER_MAX_PAGES=10
