# Local database settings for scripts/db/liquibase.sh.
# Copy to .env for local development. Do not commit real secrets.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=political_data
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Optional: override the full JDBC URL.
# DATABASE_URL=jdbc:postgresql://localhost:5432/political_data

# Optional: pin or override the Docker fallback image.
# LIQUIBASE_IMAGE=liquibase:4.33
